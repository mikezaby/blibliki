{
  "private": true,
  "version": "1.0.1",
  "author": "Michalis Zabaras",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r --sort run build",
    "build:packages": "pnpm -r --filter='./packages/*' --sort run build",
    "clean:dist": "rm -rf packages/*/dist apps/*/dist",
    "tsc": "pnpm -r --parallel --no-bail --sort run tsc",
    "lint": "pnpm -r --parallel --no-bail run lint",
    "format": "pnpm -r --parallel run format",
    "format:check": "pnpm -r --parallel --no-bail run format:check",
    "test": "pnpm -r --parallel --if-present run test",
    "storybook:check": "pnpm -C apps/storybook lint && pnpm -C apps/storybook build-storybook",
    "bump": "pnpm -r --parallel --if-present run bump",
    "release": "pnpm -r --parallel --if-present run release"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "pnpm@11.0.9",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "prettier": "3.8.3",
    "tsdown": "0.22.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  }
}
