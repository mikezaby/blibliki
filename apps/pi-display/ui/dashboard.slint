export struct DashboardCell {
    label: string,
    value: string,
    visual: string,
    accent: bool,
    inactive: bool,
    empty: bool,
}

component CellFrame inherits Rectangle {
    in property <bool> compact;
    in property <string> label;
    in property <string> value;
    in property <string> visual;
    in property <bool> accent;
    in property <bool> inactive;
    in property <bool> empty;

    background: transparent;
    border-width: 0px;

    VerticalLayout {
        padding: compact ? 2px : 4px;
        spacing: compact ? 2px : 4px;

        Text {
            text: label;
            color: empty ? #30363b : inactive ? #596168 : #8f999f;
            font-size: compact ? 11px : 15px;
            font-family: "Monospace";
            horizontal-alignment: left;
        }

        Text {
            text: value;
            color: empty ? #3b4147 : accent ? #ffb347 : inactive ? #bdb7ac : #f2efe5;
            font-size: compact ? 24px : 36px;
            font-family: "Monospace";
            horizontal-alignment: left;
        }

        Text {
            text: visual;
            color: empty ? #21262b : accent ? #d89b4b : #6f7880;
            font-size: compact ? 13px : 18px;
            font-family: "Monospace";
            horizontal-alignment: left;
        }
    }
}

component BandFrame inherits Rectangle {
    in property <bool> compact;
    in property <string> title;
    in property <[DashboardCell]> cells;
    in property <bool> accent-lane;

    background: accent-lane ? #0a0806 : #050608;
    border-width: 0px;

    VerticalLayout {
        padding: compact ? 8px : 12px;
        spacing: compact ? 6px : 10px;

        Text {
            text: title;
            color: accent-lane ? #ffb347 : #93a0a7;
            font-size: compact ? 12px : 16px;
            font-family: "Monospace";
        }

        Rectangle {
            height: 1px;
            background: accent-lane ? #3a2914 : #171c20;
        }

        HorizontalLayout {
            spacing: compact ? 12px : 18px;

            for cell in cells: CellFrame {
                horizontal-stretch: 1;
                compact: compact;
                label: cell.label;
                value: cell.value;
                visual: cell.visual;
                accent: cell.accent;
                inactive: cell.inactive;
                empty: cell.empty;
            }
        }
    }
}

export component DashboardWindow inherits Window {
    background: #010103;
    in-out property <bool> compact-layout: false;
    width: compact-layout ? 800px : 1280px;
    height: compact-layout ? 480px : 720px;
    title: "Blibliki Pi Display";

    in-out property <string> header-left: "Blibliki";
    in-out property <string> header-center: "track-1";
    in-out property <string> header-right: "Page 1: SOURCE / AMP";
    in-out property <string> transport-text: "STOP";
    in-out property <bool> transport-active: false;
    in-out property <string> global-title: "GLOBAL";
    in-out property <string> upper-title: "UPPER";
    in-out property <string> lower-title: "LOWER";
    in-out property <[DashboardCell]> global-cells: [];
    in-out property <[DashboardCell]> upper-cells: [];
    in-out property <[DashboardCell]> lower-cells: [];

    VerticalLayout {
        padding: compact-layout ? 10px : 16px;
        spacing: compact-layout ? 8px : 12px;

        Rectangle {
            height: compact-layout ? 60px : 76px;
            background: #040507;
            border-width: 0px;

            HorizontalLayout {
                padding: compact-layout ? 6px : 10px;
                spacing: compact-layout ? 10px : 16px;

                Rectangle {
                    width: compact-layout ? 156px : 220px;
                    border-width: 0px;
                    background: transparent;

                    Text {
                        text: header-left;
                        color: #f2efe5;
                        font-size: compact-layout ? 28px : 40px;
                        font-family: "Monospace";
                        vertical-alignment: center;
                        horizontal-alignment: left;
                    }
                }

                Rectangle {
                    background: transparent;
                    vertical-stretch: 1;

                    HorizontalLayout {
                        spacing: compact-layout ? 10px : 16px;

                        Text {
                            text: header-center;
                            color: #ffb347;
                            font-size: compact-layout ? 22px : 30px;
                            font-family: "Monospace";
                            vertical-alignment: center;
                        }

                        Text {
                            text: header-right;
                            color: #b3bcc2;
                            font-size: compact-layout ? 14px : 18px;
                            font-family: "Monospace";
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: transparent;
                }

                Rectangle {
                    width: compact-layout ? 84px : 110px;
                    border-width: 0px;
                    background: transport-active ? #2a1b0a : #0f1316;

                    Text {
                        text: transport-text;
                        color: transport-active ? #ffb347 : #f2efe5;
                        font-size: compact-layout ? 18px : 24px;
                        font-family: "Monospace";
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                }

            }
        }

        BandFrame {
            height: compact-layout ? 118px : 180px;
            compact: compact-layout;
            title: global-title;
            accent-lane: false;
            cells: global-cells;
        }

        BandFrame {
            height: compact-layout ? 118px : 180px;
            compact: compact-layout;
            title: upper-title;
            accent-lane: true;
            cells: upper-cells;
        }

        BandFrame {
            height: compact-layout ? 118px : 180px;
            compact: compact-layout;
            title: lower-title;
            accent-lane: false;
            cells: lower-cells;
        }
    }
}
