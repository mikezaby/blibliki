{
  "name": "@blibliki/pi-patcher",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src test",
    "tsc": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run"
  },
  "dependencies": {
    "@blibliki/engine": "workspace:^",
    "@blibliki/transport": "workspace:^",
    "@blibliki/utils": "workspace:^"
  },
  "devDependencies": {
    "@types/audioworklet": "catalog:web-audio",
    "vitest": "catalog:test"
  }
}
