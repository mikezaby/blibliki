{
  "name": "@blibliki/ui",
  "version": "0.1.2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css",
    "./tokens.css": "./tokens.css",
    "./eslint": "./eslint/index.js",
    "./eslint/ui-governance-plugin": "./eslint/ui-governance-plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "src",
    "dist",
    "eslint",
    "scripts",
    "styles.css",
    "tokens.css"
  ],
  "scripts": {
    "build": "tsdown",
    "clean:dist": "rm -rf ./dist",
    "dev": "tsdown --watch --no-clean",
    "lint:palette": "node scripts/check-css-palette.mjs",
    "lint": "pnpm run lint:palette && eslint src",
    "tsc": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "bump": "npm version patch",
    "release": "pnpm run build && pnpm publish --access public"
  },
  "dependencies": {
    "@blibliki/utils": "workspace:^",
    "@radix-ui/react-context-menu": "2.3.1",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-dropdown-menu": "2.1.18",
    "@radix-ui/react-label": "2.1.10",
    "@radix-ui/react-select": "2.3.1",
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "catalog:tailwindcss"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/react": "catalog:react-19",
    "@types/react-dom": "catalog:react-19",
    "react": "catalog:react-19",
    "react-dom": "catalog:react-19"
  }
}
